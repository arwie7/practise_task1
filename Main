public class Main {
    public static void main(String[] args) {
        BankAccount alice = new BankAccount("Alice");
        BankAccount bob = new BankAccount("Bob");

        System.out.println("Initial balances:");
        System.out.println(alice.getOwnerName() + ": " + alice.getBalance());
        System.out.println(bob.getOwnerName() + ": " + bob.getBalance());

        System.out.println("\nDeposit 1000 to Alice: " + alice.deposit(1000));
        System.out.println("Alice balance: " + alice.getBalance());

        System.out.println("\nWithdraw 300 from Alice: " + alice.withdraw(300));
        System.out.println("Alice balance: " + alice.getBalance());

        System.out.println("\nTransfer 500 from Alice to Bob: " + alice.transfer(bob, 500));
        System.out.println("Alice balance: " + alice.getBalance());
        System.out.println("Bob balance: " + bob.getBalance());

        System.out.println("\nTry to withdraw 5000 from Bob: " + bob.withdraw(5000));
        System.out.println("Bob balance: " + bob.getBalance());

        bob.setBlocked(true);
        System.out.println("\nTry to transfer 100 from Alice to blocked Bob: " + alice.transfer(bob, 100));
        System.out.println("Alice balance: " + alice.getBalance());
        System.out.println("Bob balance: " + bob.getBalance());
    }
}
